// easy-nfe — schema de domínio (emissão NF-e modelo 55).
// Mapeia lib/types.ts + dados de autorização SEFAZ.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------
enum Ambiente {
  HOMOLOGACAO
  PRODUCAO
}

enum StatusNota {
  RASCUNHO
  AUTORIZADA
  CANCELADA
  REJEITADA
  DENEGADA
}

enum Role {
  USER
  SUPORTE
  ADMIN
  CONTADOR
}

enum StatusLicenca {
  TRIAL
  ATIVA
  EXPIRADA
  SUSPENSA
  CANCELADA
}

enum StatusFatura {
  PENDENTE
  PAGA
  ATRASADA
  CANCELADA
}

enum StatusLead {
  NOVO
  CONTATADO
  CONVERTIDO
  DESCARTADO
}

// ----------------------------------------------------------------------------
// Usuário (login). Um usuário pode administrar várias empresas (emitentes).
// ----------------------------------------------------------------------------
model User {
  id        String  @id @default(uuid())
  email     String  @unique
  senhaHash String
  nome      String?
  role      Role    @default(USER)
  ativo     Boolean @default(true)

  // Cobrança da assinatura (Asaas)
  cpfCnpj         String?
  telefone        String?
  asaasCustomerId String? // id do cliente no Asaas (reaproveitado entre faturas)

  // Aceite de Termos de Uso + Política de Privacidade (LGPD)
  aceiteTermosEm DateTime?

  // Tutoriais/onboarding já vistos por este usuário (chaves livres). Persiste
  // por usuário (não por navegador) — não reaparece em outro dispositivo.
  toursVistos String[] @default([])

  empresas Emitente[] // empresas criadas por este usuário (dono original)
  acessos  AcessoEmpresa[]
  licenca  Licenca?
  faturas  Fatura[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

// ----------------------------------------------------------------------------
// SaaS: planos, licenças e pagamentos.
// ----------------------------------------------------------------------------
model Plano {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  preco          Decimal  @default(0) @db.Decimal(10, 2)
  precoAntigo    Decimal? @db.Decimal(10, 2) // valor "de" (riscado) opcional
  sobConsulta    Boolean  @default(false) // sem preço fixo → "Fale com vendedores"
  categoria      String? // agrupamento na landing (ex.: "Para começar", "Para crescer")
  periodicidade  String   @default("mensal") // mensal | anual
  limiteEmpresas Int      @default(1) // -1 = ilimitado
  limiteUsuarios Int      @default(1) // membros por empresa; -1 = ilimitado
  recursos       String[] // legado (texto livre) — substituído por `beneficios`
  ativo          Boolean  @default(true) // exibido na LP / disponível
  popular        Boolean  @default(false) // destaque "mais popular" na landing
  permiteTrial   Boolean  @default(false) // libera teste grátis de 7 dias (botão na landing + cadastro self-serve)
  ordem          Int      @default(0)

  beneficios Beneficio[]
  licencas   Licenca[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("planos")
}

// Categorias de plano (agrupamento na landing).
model CategoriaPlano {
  id        String   @id @default(uuid())
  nome      String   @unique
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("categorias_plano")
}

// Catálogo de benefícios/permissões que podem ser atribuídos a planos.
model Beneficio {
  id        String   @id @default(uuid())
  chave     String   @unique
  nome      String
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  oculto    Boolean  @default(false) // não aparece no catálogo (aba Benefícios), só no modal de plano
  features  String[] // chaves de funcionalidades que este benefício libera

  planos    Plano[]
  createdAt DateTime @default(now())

  @@map("beneficios")
}

model Licenca {
  id         String        @id @default(uuid())
  userId     String        @unique
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  planoId    String?
  plano      Plano?        @relation(fields: [planoId], references: [id])
  status     StatusLicenca @default(TRIAL)
  inicioEm   DateTime      @default(now())
  validadeEm DateTime?

  // Assinatura recorrente no cartão (Asaas Subscriptions)
  asaasSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("licencas")
}

// "Fatura" (cobrança por período) gerada a partir do plano/validade da licença.
model Fatura {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  planoNome   String // snapshot do nome do plano
  competencia String // período de referência, ex.: "2026-06"
  valor       Decimal      @db.Decimal(10, 2)
  vencimento  DateTime
  status      StatusFatura @default(PENDENTE)
  pagaEm      DateTime?
  metodo      String? // pix | cartao | boleto | transferencia (ao marcar paga)

  // Cobrança Asaas
  asaasPaymentId String? @unique
  bankSlipUrl    String? // PDF do boleto
  invoiceUrl     String? // fatura/checkout Asaas
  linhaDigitavel String? // identificationField (linha digitável)
  pixCopiaECola  String? @db.Text // payload Pix copia-e-cola
  pixQrImage     String? @db.Text // QR code Pix (imagem base64)

  // Pagamento público (sem login): /pagar/[token]
  tokenPublico String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, competencia])
  @@index([userId])
  @@map("faturas")
}

// Pedido de contato vindo da landing (planos "sob consulta" ou quem prefere falar
// com vendas). Não cria conta — vendas dá sequência.
model Lead {
  id        String     @id @default(uuid())
  nome      String
  email     String
  telefone  String?
  empresa   String? // nome/razão da empresa informado
  planoId   String? // plano de interesse (solto, sem FK)
  planoNome String? // snapshot do nome do plano
  mensagem  String?
  status    StatusLead @default(NOVO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("leads")
}

// Vínculo M—N usuário <-> empresa (acesso compartilhado).
model AcessoEmpresa {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  papel     String   @default("membro") // dono | membro
  createdAt DateTime @default(now())

  @@unique([userId, empresaId])
  @@index([empresaId])
  @@map("acessos_empresa")
}

// ----------------------------------------------------------------------------
// Emitente / configuração fiscal (empresa que emite)
// ----------------------------------------------------------------------------
model Emitente {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cnpj         String
  razaoSocial  String
  nomeFantasia String?
  ie           String // inscrição estadual
  crt          String // 1=Simples, 2=Simples-excesso, 3=Regime normal

  // endereço (flat)
  cep          String
  logradouro   String
  numero       String
  complemento  String?
  bairro       String
  codMunicipio String // IBGE
  municipio    String
  uf           String

  telefone String?
  email    String?

  // emissão
  ambiente      Ambiente @default(HOMOLOGACAO)
  serie         Int      @default(1)
  proximoNumero Int      @default(1)

  // casas decimais permitidas na quantidade dos itens (qCom). 0–4. Padrão 2.
  casasDecimaisQtd Int @default(2)

  // Controle de estoque: bloquear emissão quando algum item controlado não tem
  // saldo suficiente. false = só baixa (permite negativo, estoque é indicador).
  bloquearSemEstoque Boolean @default(false)

  // Padrões de emissão — parametrizam a tela de emitir nota p/ agilizar o fluxo.
  tipoNotaPadrao         String  @default("55-saida") // pré-seleciona o tipo no passo 1
  travarTipoNota         Boolean @default(false) // trava o tipo (esconde o seletor)
  definirTransporte      Boolean @default(true) // false = pula o passo de transporte
  modFretePadrao         String  @default("9") // modalidade de frete padrão (modFrete)
  infoComplementarPadrao String? // texto padrão em "informações complementares"
  clientePadraoId        String? // cliente pré-selecionado ao emitir (opcional)

  // NFC-e (modelo 65) — série/numeração próprias + CSC (Código de Segurança do
  // Contribuinte) emitido pela SEFAZ, usado no hash do QR Code.
  serieNFCe         Int     @default(1)
  proximoNumeroNFCe Int     @default(1)
  cscNFCe           String? // texto do CSC (segredo)
  idCscNFCe         String? // identificador do CSC (cIdToken), 1-6 dígitos

  // NFS-e (serviço — Padrão Nacional). ISS é municipal: exige inscrição
  // municipal e CNAE. Regime do Simples define se ISS é destacado ou recolhido
  // no DAS. Série/numeração próprias da DPS/NFS-e.
  inscricaoMunicipal String?
  cnae               String?
  opSimpNac          String  @default("1") // 1=Não optante, 2=MEI, 3=ME/EPP
  regApTribSN        String? // regime apuração Simples (1/2/3) — quando opSimpNac=3
  regEspTrib         String? // regime especial tributação (0-9)
  serieNFSe          Int     @default(1)
  proximoNumeroNFSe  Int     @default(1)

  // certificado A1 — PFX+senha criptografados (AES-256-GCM) + metadados
  certData      String?   @db.Text
  certTitular   String?
  certValidoAte DateTime?

  // Distribuição DFe — cursor do último NSU consultado na SEFAZ (Ambiente Nacional).
  dfeUltNSU    String?
  dfeMaxNSU    String?
  dfeSincNSUEm DateTime?

  notas             Nota[]
  notasServico      NotaServico[]
  servicos          Servico[]
  orcamentos        Orcamento[]
  notasRecebidas    NotaRecebida[]
  produtos          Produto[]
  clientes          Cliente[]
  fornecedores      Fornecedor[]
  transportadoras   Transportadora[]
  categorias        Categoria[]
  acessos           AcessoEmpresa[]
  whatsapp          ConfigWhatsApp?
  movimentosEstoque MovimentoEstoque[]
  entradasEstoque   EntradaEstoque[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cnpj])
  @@map("emitentes")
}

// ----------------------------------------------------------------------------
// Categorias (de produto OU de cliente) — escopadas à empresa. O campo `tipo`
// separa os dois conjuntos ("produto" | "cliente"). Gerenciadas pelas próprias
// páginas de produtos/clientes.
// ----------------------------------------------------------------------------
model Categoria {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  tipo String // "produto" | "cliente"
  nome String
  cor  String? // cor opcional do rótulo (hex)

  produtos Produto[] @relation("CategoriaProduto")
  clientes Cliente[] @relation("CategoriaCliente")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, tipo, nome])
  @@index([empresaId, tipo])
  @@map("categorias")
}

// ----------------------------------------------------------------------------
// Produtos
// ----------------------------------------------------------------------------
model Produto {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigoInterno Int      @unique @default(autoincrement())
  codigoBarras  String? // cEAN / GTIN
  nome          String
  marca         String?
  peso          Decimal? @db.Decimal(15, 3) // peso líquido em kg
  unidade       String
  ncm           String
  origem        String // 0-8
  preco         Decimal  @db.Decimal(15, 2)
  descricao     String?

  categoriaId String?
  categoria   Categoria? @relation("CategoriaProduto", fields: [categoriaId], references: [id], onDelete: SetNull)

  // fiscais
  cfopPadrao           String?
  csosn                String? // Simples
  cst                  String? // Regime normal: "40" isenção (padrão) | "20" redução de BC
  aliquotaIcms         Decimal? @db.Decimal(5, 2) // pICMS p/ CST 20 (ex.: 17,00)
  reducaoBaseIcms      Decimal? @db.Decimal(5, 2) // pRedBC % p/ CST 20 (ex.: 58,82)
  cest                 String?
  codigoBeneficio      String?
  creditoPresumidoIcms String?
  reguladoAnp          Boolean  @default(false)

  // Estoque. controlaEstoque = opt-in; só produtos marcados têm baixa na emissão.
  estoque         Decimal @default(0) @db.Decimal(15, 4)
  estoqueMinimo   Decimal @default(0) @db.Decimal(15, 4) // alerta quando saldo <= mínimo
  controlaEstoque Boolean @default(false)

  itens             ItemNota[]
  itensOrcamento    ItemOrcamento[]
  movimentosEstoque MovimentoEstoque[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("produtos")
}

// ----------------------------------------------------------------------------
// Movimentos de estoque — histórico de entradas/saídas/ajustes por produto.
// quantidade é sempre positiva; o sinal vem do tipo. saldoApos = saldo após.
// ----------------------------------------------------------------------------
enum TipoMovimentoEstoque {
  ENTRADA // compra/entrada por XML/ajuste positivo
  SAIDA // emissão de NF-e
  AJUSTE // ajuste manual (pode ser + ou -, ver quantidade vs saldoApos)
  DEVOLUCAO // devolução de venda — itens voltam ao estoque
}

model MovimentoEstoque {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  tipo          TipoMovimentoEstoque
  quantidade    Decimal              @db.Decimal(15, 4) // delta absoluto (sempre > 0)
  saldoApos     Decimal              @db.Decimal(15, 4)
  custoUnitario Decimal?             @db.Decimal(15, 10) // custo de entrada (p/ custo médio futuro)
  motivo        String?

  notaId String?
  nota   Nota?   @relation(fields: [notaId], references: [id], onDelete: SetNull)

  entradaId String?
  entrada   EntradaEstoque? @relation(fields: [entradaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([empresaId, produtoId])
  @@index([notaId])
  @@index([entradaId])
  @@map("movimentos_estoque")
}

// Entrada de mercadoria a partir do XML de uma NF-e de compra/recebida.
// Única por (empresa, chave) — reimportar a mesma nota não duplica estoque.
model EntradaEstoque {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  chave          String // chave de acesso da NF-e de origem
  numero         String?
  serie          String?
  modelo         String?
  fornecedorNome String?
  fornecedorDoc  String?
  valorTotal     Decimal? @db.Decimal(15, 2)

  movimentos MovimentoEstoque[]

  createdAt DateTime @default(now())

  @@unique([empresaId, chave])
  @@index([empresaId])
  @@map("entradas_estoque")
}

// ----------------------------------------------------------------------------
// Clientes (destinatários)
// ----------------------------------------------------------------------------
model Cliente {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigoInterno     Int     @unique @default(autoincrement())
  padrao            Boolean @default(false) // "Consumidor final" do sistema (não editável/excluível)
  tipoContribuinte  String // 1 / 2 / 9
  documento         String // CPF ou CNPJ (vazio no Consumidor final)
  nome              String
  inscricaoEstadual String?

  categoriaId String?
  categoria   Categoria? @relation("CategoriaCliente", fields: [categoriaId], references: [id], onDelete: SetNull)

  telefone String?
  email    String?

  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  codMunicipio String?
  municipio    String?
  uf           String?

  notas        Nota[]
  notasServico NotaServico[]
  orcamentos   Orcamento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("clientes")
}

// ----------------------------------------------------------------------------
// Fornecedores (empresas que faturam CONTRA o CNPJ da empresa). Casados pelo
// CNPJ do emitente das notas recebidas (Distribuição DFe) p/ identificar a origem.
// ----------------------------------------------------------------------------
model Fornecedor {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigoInterno     Int     @unique @default(autoincrement())
  documento         String // CNPJ (ou CPF)
  nome              String // razão social
  nomeFantasia      String?
  inscricaoEstadual String?

  telefone String?
  email    String?

  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  codMunicipio String?
  municipio    String?
  uf           String?

  observacoes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, documento])
  @@index([empresaId])
  @@map("fornecedores")
}

// ----------------------------------------------------------------------------
// Transportadoras
// ----------------------------------------------------------------------------
model Transportadora {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigoInterno     Int     @unique @default(autoincrement())
  tipoTransporte    String // modalidade frete 0-4,9
  documento         String
  nome              String
  inscricaoEstadual String?

  telefone String?
  email    String?

  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  codMunicipio String?
  municipio    String?
  uf           String?

  notas      Nota[]
  orcamentos Orcamento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("transportadoras")
}

// ----------------------------------------------------------------------------
// Notas (NF-e)
// ----------------------------------------------------------------------------
model Nota {
  id               String @id @default(uuid())
  numero           Int
  serie            Int    @default(1)
  modelo           String @default("55")
  naturezaOperacao String @default("VENDA DE MERCADORIA")
  tipoNota         String // ex.: "55-saida"

  emitenteId String
  emitente   Emitente @relation(fields: [emitenteId], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  transportadoraId String?
  transportadora   Transportadora? @relation(fields: [transportadoraId], references: [id])

  itens             ItemNota[]
  orcamento         Orcamento? // orçamento que gerou esta nota (quando convertido)
  movimentosEstoque MovimentoEstoque[]

  informacoesAdicionais String?
  status                StatusNota @default(RASCUNHO)
  ambiente              Ambiente   @default(HOMOLOGACAO)
  valorTotal            Decimal    @default(0) @db.Decimal(15, 2)

  // autorização SEFAZ
  chaveAcesso   String?   @unique
  protocolo     String?
  autorizadaEm  DateTime?
  xmlAutorizado String?   @db.Text

  // NFC-e: conteúdo do QR Code (para o DANFE em cupom)
  qrCode String? @db.Text

  // cancelamento
  protocoloCancelamento     String?
  justificativaCancelamento String?
  canceladaEm               DateTime?
  xmlCancelamento           String?   @db.Text

  // rejeição
  cStat   String?
  xMotivo String?

  emitidaEm DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([emitenteId, modelo, serie, numero])
  @@index([status])
  @@map("notas")
}

model ItemNota {
  id     String @id @default(uuid())
  notaId String
  nota   Nota   @relation(fields: [notaId], references: [id], onDelete: Cascade)

  produtoId String?
  produto   Produto? @relation(fields: [produtoId], references: [id])

  // snapshots (preservam valores no momento da emissão)
  nome          String
  ncm           String?
  cfop          String?
  unidade       String?
  quantidade    Decimal @db.Decimal(15, 4)
  precoUnitario Decimal @db.Decimal(15, 10)
  valorTotal    Decimal @db.Decimal(15, 2)

  @@map("itens_nota")
}

// ----------------------------------------------------------------------------
// Serviços (catálogo) — análogo a Produto, porém fiscal de serviço (NFS-e).
// Classificação pela LC 116/2003: cTribNac (código tributação nacional) e item
// da lista. cNBS é a Nomenclatura Brasileira de Serviços. ISS é municipal.
// ----------------------------------------------------------------------------
model Servico {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigoInterno Int     @unique @default(autoincrement())
  nome          String
  descricao     String? // base do xDescServ na DPS

  // fiscais (NFS-e nacional)
  cTribNac         String // 6 dígitos — código de tributação nacional (LC 116)
  itemListaServico String? // item da lista LC 116 (ex.: "01.07")
  cNBS             String? // 9 dígitos — Nomenclatura Brasileira de Serviços
  aliqISS          Decimal? @db.Decimal(5, 2) // alíquota ISS % (quando destacado)
  valorUnit        Decimal  @db.Decimal(15, 2)

  notasServico NotaServico[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("servicos")
}

// ----------------------------------------------------------------------------
// Notas de serviço (NFS-e — Padrão Nacional). A DPS (Declaração de Prestação de
// Serviço) é o documento que o contribuinte assina e transmite; a NFS-e é o que
// o fisco devolve (chave de acesso de 50 dígitos). Uma DPS = um serviço.
// ----------------------------------------------------------------------------
model NotaServico {
  id     String @id @default(uuid())
  numero Int // nNFSe / nDPS
  serie  Int    @default(1)

  emitenteId String
  emitente   Emitente @relation(fields: [emitenteId], references: [id])

  clienteId String // tomador do serviço
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // serviço (snapshot no momento da emissão)
  servicoId             String?
  servico               Servico? @relation(fields: [servicoId], references: [id])
  descricaoServico      String
  cTribNac              String
  itemListaServico      String?
  cNBS                  String?
  codMunicipioPrestacao String // IBGE 7 (local da prestação)

  // valores e ISS
  valorServico Decimal  @db.Decimal(15, 2)
  aliqISS      Decimal? @db.Decimal(5, 2)
  valorISS     Decimal? @db.Decimal(15, 2)
  issRetido    Boolean  @default(false) // tpRetISSQN != 1
  tribISSQN    String   @default("1") // 1=tributável 2=imune 3=exportação 4=não incidência

  competencia DateTime // dCompet

  informacoesAdicionais String?
  status                StatusNota @default(RASCUNHO)
  ambiente              Ambiente   @default(HOMOLOGACAO)

  // autorização (Padrão Nacional)
  chaveAcesso  String?   @unique // 50 dígitos
  dpsId        String? // Id da DPS transmitida
  protocolo    String?
  autorizadaEm DateTime?
  xmlDps       String?   @db.Text // DPS assinada enviada
  xmlNfse      String?   @db.Text // NFS-e devolvida pelo fisco

  // cancelamento (evento)
  canceladaEm               DateTime?
  justificativaCancelamento String?
  xmlCancelamento           String?   @db.Text

  // rejeição
  cStat   String?
  xMotivo String?

  emitidaEm DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([emitenteId, serie, numero])
  @@index([status])
  @@map("notas_servico")
}

// ----------------------------------------------------------------------------
// Notas recebidas (Distribuição DFe) — documentos emitidos CONTRA o CNPJ da
// empresa, baixados da SEFAZ. Inclui resumos (NFe), notas completas (procNFe)
// e eventos. A manifestação do destinatário é registrada aqui.
// ----------------------------------------------------------------------------
enum ManifestacaoTipo {
  PENDENTE // ainda não manifestada
  CIENCIA // 210210 — Ciência da Operação
  CONFIRMACAO // 210200 — Confirmação da Operação
  DESCONHECIMENTO // 210220 — Desconhecimento da Operação
  NAO_REALIZADA // 210240 — Operação não Realizada
}

model NotaRecebida {
  id String @id @default(uuid())

  empresaId String
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  nsu     String // NSU do documento na Distribuição DFe
  schema  String // ex.: "resNFe_v1.01.xsd", "procNFe_v4.00.xsd", "resEvento_v1.01.xsd"
  tipoDoc String // "resumo" | "nfe" | "evento"

  chaveAcesso  String? // chNFe (44 dígitos) quando aplicável
  emitenteCnpj String?
  emitenteNome String?
  valorTotal   Decimal?  @db.Decimal(15, 2)
  emitidaEm    DateTime?
  descricao    String? // descEvento / situação, p/ documentos de evento

  xml String @db.Text // XML bruto do documento (resumo ou nota completa)

  manifestacao       ManifestacaoTipo @default(PENDENTE)
  manifestadaEm      DateTime?
  protocoloManifesto String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, nsu])
  @@index([empresaId, chaveAcesso])
  @@map("notas_recebidas")
}

// ----------------------------------------------------------------------------
// Configuração global do sistema (key-value). Valores sensíveis são guardados
// criptografados (AES-256-GCM via lib/crypto). Ex.: integração Asaas.
// ----------------------------------------------------------------------------
model ConfigSistema {
  chave     String   @id
  valor     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("config_sistema")
}

// ----------------------------------------------------------------------------
// Envio de NF-e por WhatsApp — config por empresa. A sessão do WhatsApp (pareada
// via QR Code) vive num worker externo sempre-ligado (Baileys); aqui guardamos
// apenas as preferências e o espelho do estado de conexão reportado pelo worker.
// ----------------------------------------------------------------------------
model ConfigWhatsApp {
  id String @id @default(uuid())

  empresaId String   @unique
  empresa   Emitente @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  conectado    Boolean @default(false) // espelho do status do worker
  telefone     String? // número (JID) conectado, preenchido pelo worker
  ativaEmissao Boolean @default(false) // envia automaticamente ao autorizar a nota
  enviarDanfe  Boolean @default(true) // anexa o PDF do DANFE (gerado no worker)
  template     String? @db.Text // mensagem; null = usa o padrão do sistema

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("config_whatsapp")
}

// ----------------------------------------------------------------------------
// Orçamentos (funil de vendas) — vira NF-e ao fechar a venda.
// ----------------------------------------------------------------------------
enum StatusOrcamento {
  RASCUNHO // em elaboração
  ENVIADO // enviado ao cliente
  NEGOCIACAO // em negociação
  APROVADO // aprovado pelo cliente
  FECHADO // virou NF-e (venda fechada)
  PERDIDO // não fechou
  CANCELADO // cancelado
}

model Orcamento {
  id     String @id @default(uuid())
  numero Int

  emitenteId String
  emitente   Emitente @relation(fields: [emitenteId], references: [id], onDelete: Cascade)

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  transportadoraId String?
  transportadora   Transportadora? @relation(fields: [transportadoraId], references: [id])

  tipoNota    String    @default("55-saida") // modelo da NF ao fechar
  modFrete    String    @default("9")
  observacoes String?
  validade    DateTime? // até quando o orçamento vale

  descontoTipo  String  @default("valor") // "valor" | "percent"
  descontoValor Decimal @default(0) @db.Decimal(15, 2)

  status      StatusOrcamento @default(RASCUNHO)
  ordem       Int             @default(0) // posição dentro da coluna do kanban
  valorTotal  Decimal         @default(0) @db.Decimal(15, 2)
  motivoPerda String?

  // Nota gerada ao fechar a venda.
  notaId String? @unique
  nota   Nota?   @relation(fields: [notaId], references: [id])

  itens ItemOrcamento[]

  criadoEm  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([emitenteId, numero])
  @@index([emitenteId, status])
  @@map("orcamentos")
}

model ItemOrcamento {
  id          String    @id @default(uuid())
  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  produtoId String?
  produto   Produto? @relation(fields: [produtoId], references: [id])

  nome          String // snapshot
  ncm           String?
  cfop          String?
  unidade       String?
  quantidade    Decimal @db.Decimal(15, 4)
  precoUnitario Decimal @db.Decimal(15, 10)
  descontoTipo  String  @default("valor")
  descontoValor Decimal @default(0) @db.Decimal(15, 2)
  valorTotal    Decimal @db.Decimal(15, 2)

  @@map("itens_orcamento")
}
